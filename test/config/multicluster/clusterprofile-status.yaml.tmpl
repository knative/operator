# Status subresource patch for the spoke ClusterProfile.
# Used by apply_cluster_profile in e2e-common.sh.
status:
  accessProviders:
  - name: "${MC_PROVIDER_NAME}"
    cluster:
      server: "${SPOKE_INTERNAL_ENDPOINT}"
      certificate-authority-data: "${SPOKE_CA_DATA_B64}"
      extensions:
      - name: client.authentication.k8s.io/exec
        extension:
          clusterName: "${SPOKE_CLUSTER_NAME}"
  conditions:
  - type: ControlPlaneHealthy
    status: "True"
    reason: E2EHarness
    message: "spoke kind cluster reachable"
    lastTransitionTime: "${TRANSITION}"
